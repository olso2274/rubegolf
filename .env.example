# Public (browser + server reads)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only: API upserts (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional: force PGA leaderboard tournament id when message.json has no tid (common during Masters).
# From leaderboard URL path: .../tournaments/2026/masters-tournament/R2026014/leaderboard → use R2026014
# PGA_TOURNAMENT_ID=R2026014

# Secured route: GitHub Actions cron, or admin "Force update" (same secret in GitHub repo secrets)
CRON_SECRET=

# Public "Sync scores" button — set to "false" to disable POST /api/public-scores-sync
# PUBLIC_SCORE_SYNC_ENABLED=true

# Cooldown between public syncs (seconds). Default 300.
# PUBLIC_SYNC_COOLDOWN_SECONDS=300

# Admin UI (/admin) — set both; cookie token is derived from these
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=long-random-string
