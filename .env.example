# Public (browser + server reads)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only: API upserts (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Vercel Cron: Project Settings → add CRON_SECRET; Vercel sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Admin UI (/admin) — set both; cookie token is derived from these
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=long-random-string
